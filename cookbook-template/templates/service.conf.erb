# Configuration file for <%= @service_name %>
# Generated by Chef - DO NOT EDIT MANUALLY

[service]
port = <%= @port %>
enabled = <%= @enabled %>
user = <%= @user %>
group = <%= @group %>

[logging]
level = <%= node['cookbook_template']['logging']['level'] %>
file = <%= node['cookbook_template']['logging']['file'] %>
max_size = <%= node['cookbook_template']['logging']['max_size'] %>
rotate_count = <%= node['cookbook_template']['logging']['rotate_count'] %>

[network]
bind_address = 127.0.0.1
timeout = 30

<% if @include_metadata %>
# Chef node information
[metadata]
node_name = <%= node.name %>
chef_environment = <%= node.chef_environment %>
platform = <%= node['platform'] %>
platform_version = <%= node['platform_version'] %>
cookbook_version = <%= run_context.cookbook_collection['cookbook-template'].version %>
<% end %>