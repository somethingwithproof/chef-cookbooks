# Generated by Chef on node <%= node['fqdn'] %>
# Local modifications will be overwritten.
###############################################################################
#
# SNMPTRAPD.CONF
#   Configuration file for the SNMP trap daemon.
#
###############################################################################

# TRAP HANDLER
# ------------
# The trap handler specifies what to do with received traps.
traphandle <%= node['snmp']['snmptrapd']['traphandle'] %>

# AUTHENTICATION CONTROL
# ---------------------
# Controls whether SNMP traps require authentication.
disableAuthorization <%= node['snmp']['snmptrapd']['disableAuthorization'] %>

# TRAP LOGGING
# -----------
# Controls whether traps are logged by the daemon.
donotlogtraps <%= node['snmp']['snmptrapd']['donotlogtraps'] %>

# TRAP COMMUNITY STRING
# --------------------
# Community string for incoming traps 
authCommunity log,execute,net <%= @trap_community %>

# TRAP PROCESSING
# --------------
<% unless @trap_addresses.empty? %>
# Forward traps to specified addresses
<% @trap_addresses.each do |address| %>
forward default <%= address %>:<%= @trap_port %>
<% end %>
<% end %>