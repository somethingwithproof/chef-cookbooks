#!/bin/sh
#
# Pre-commit hook to run cookstyle linting with auto-correction
#
echo "Running cookstyle checks..."

# Get a list of staged Ruby files
STAGED_FILES=$(git diff --cached --name-only --diff-filter=ACM | grep -E '\.(rb)$')

if [ "$STAGED_FILES" = "" ]; then
  echo "No Ruby files to check. Skipping cookstyle."
  exit 0
fi

# Run cookstyle via bundle on staged files with auto-correction
echo "Running cookstyle on staged files..."
if command -v bundle &> /dev/null; then
  bundle exec cookstyle --auto-correct $STAGED_FILES
else
  echo "Bundler is not installed. Please install it with: gem install bundler"
  exit 1
fi

RESULT=$?

if [ $RESULT -ne 0 ]; then
  echo "Cookstyle found issues that could not be auto-corrected. Please fix them before committing."
  exit 1
fi

# Re-stage the corrected files
for file in $STAGED_FILES; do
  if [ -f "$file" ]; then
    git add "$file"
  fi
done

echo "Cookstyle checks passed! Auto-corrections re-staged."
exit 0