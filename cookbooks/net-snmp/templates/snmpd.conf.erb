# Managed by Chef - DO NOT EDIT
# SNMPv3 Configuration

# Disable SNMPv1 and SNMPv2c for security
# Only SNMPv3 users configured below will have access

# System information
syslocation Server Room
syscontact Admin <admin@example.com>

# SNMPv3 user configuration
<% @snmpv3_users.each do |user| -%>
# User: <%= user['username'] %>
rouser <%= user['username'] %> priv
<% end -%>

# Restrict access to localhost and SNMPv3 authenticated users
agentAddress udp:161,udp6:[::1]:161

# Disable older protocol versions
# com2sec notConfigUser  default       public
# group   notConfigGroup v1            notConfigUser
# group   notConfigGroup v2c           notConfigUser

# Views - restrict to safe OIDs
view systemonly included .1.3.6.1.2.1.1
view systemonly included .1.3.6.1.2.1.25.1

# Access control for SNMPv3 users
# Format: access GROUP CONTEXT MODEL LEVEL PREFX READ WRITE NOTIFY
