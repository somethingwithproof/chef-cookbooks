# Managed by Chef - DO NOT EDIT MANUALLY
#
# Net-SNMP Configuration
# Generated by net-snmp cookbook
#

###############################################################################
# SYSTEM INFORMATION
###############################################################################
sysLocation    <%= @sys_location %>
sysContact     <%= @sys_contact %>
sysName        <%= @sys_name %>

###############################################################################
# AGENT CONFIGURATION
###############################################################################
agentAddress <%= @listen_address %>

# Include additional configuration files
includeDir /etc/snmp/snmpd.conf.d

###############################################################################
# VIEW DEFINITIONS
###############################################################################
<% @views.each do |view| -%>
view <%= view[:name] %> <%= view[:type] %> <%= view[:oid] %><%= view[:mask] ? " #{view[:mask]}" : '' %>
<% end -%>

###############################################################################
# ACCESS CONTROL - SNMPv2c (Community Strings)
###############################################################################
<% @community_strings.each do |cs| -%>
<% if cs[:source] -%>
<%= cs[:access] || 'rocommunity' %> <%= cs[:community] %> <%= cs[:source] %><%= cs[:view] ? " -V #{cs[:view]}" : '' %>
<% else -%>
<%= cs[:access] || 'rocommunity' %> <%= cs[:community] %><%= cs[:view] ? " -V #{cs[:view]}" : '' %>
<% end -%>
<% end -%>

###############################################################################
# GROUP DEFINITIONS
###############################################################################
<% @groups.each do |group| -%>
group <%= group[:name] %> <%= group[:model] || 'usm' %> <%= group[:security_name] %>
<% end -%>

###############################################################################
# ACCESS RULES
###############################################################################
<% @access_rules.each do |rule| -%>
access <%= rule[:group] %> "" <%= rule[:model] || 'usm' %> <%= rule[:level] || 'authPriv' %> exact <%= rule[:read_view] || 'none' %> <%= rule[:write_view] || 'none' %> <%= rule[:notify_view] || 'none' %>
<% end -%>

###############################################################################
# DISK MONITORING
###############################################################################
<% @disk_monitoring.each do |disk| -%>
<% if disk.is_a?(Hash) -%>
disk <%= disk[:path] %> <%= disk[:min_percent] || 10 %>%
<% else -%>
disk <%= disk %>
<% end -%>
<% end -%>

###############################################################################
# LOAD MONITORING
###############################################################################
<% if @load_thresholds && !@load_thresholds.empty? -%>
load <%= @load_thresholds['1min'] || 12 %> <%= @load_thresholds['5min'] || 10 %> <%= @load_thresholds['15min'] || 5 %>
<% end -%>

###############################################################################
# EXTEND SCRIPTS
###############################################################################
<% @extend_scripts.each do |script| -%>
extend <%= script[:name] %> <%= script[:command] %>
<% end -%>

###############################################################################
# PASS SCRIPTS
###############################################################################
<% @pass_scripts.each do |script| -%>
pass <%= script[:oid] %> <%= script[:command] %>
<% end -%>

###############################################################################
# SECURITY SETTINGS
###############################################################################
# Disable deprecated protocols by default
# SNMPv1 and v2c are cleartext - use SNMPv3 for production
