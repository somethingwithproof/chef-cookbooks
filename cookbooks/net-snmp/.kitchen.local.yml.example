---
# Kitchen local configuration example
# Copy this to .kitchen.local.yml and customize with your test credentials
# DO NOT commit .kitchen.local.yml to version control

# Override suite attributes for testing with SNMPv3 credentials
suites:
  - name: snmpv3
    attributes:
      net_snmp:
        v3_users:
          - username: testuser
            auth_protocol: SHA-256
            auth_password: <%= ENV['SNMP_TEST_AUTH_PASSWORD'] || 'changeme_auth_password' %>
            priv_protocol: AES-256
            priv_password: <%= ENV['SNMP_TEST_PRIV_PASSWORD'] || 'changeme_priv_password' %>

# To use environment variables:
# export SNMP_TEST_AUTH_PASSWORD="your_secure_auth_password"
# export SNMP_TEST_PRIV_PASSWORD="your_secure_priv_password"
# kitchen test snmpv3
